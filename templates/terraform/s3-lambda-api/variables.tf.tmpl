variable "name" {
  type        = string
  description = "Workload name."
  default     = "$name"
}

variable "region" {
  type        = string
  description = "AWS region."
  default     = "$region"
}

variable "environment" {
  type        = string
  description = "Deployment environment."
  default     = "$environment"
}

variable "owner" {
  type        = string
  description = "Owning team or email."
  default     = "$owner"
}

variable "cost_center" {
  type        = string
  description = "Cost allocation identifier."
  default     = "$cost_center"
}

locals {
  tags = {
    Environment = var.environment
    Owner       = var.owner
    CostCenter  = var.cost_center
    ManagedBy   = "agentcore-multi-agent-deployer"
  }
}
