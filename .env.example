APP_ENV=local
AWS_REGION=us-east-1
ORCHESTRATOR_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Use a GitHub App in production. A fine-scoped token is acceptable for local MVP testing.
GITHUB_TOKEN=
GITHUB_OWNER=
REFERENCE_LIBRARY_REPO=iac-codebase-agentic-ai
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
AGENT_LLM_ENABLED=true

# Optional enterprise standards source. Start with text/markdown; add Confluence credentials later.
COMPANY_STANDARDS_PATH=./samples/company-standards.md

# AgentCore runtime identifiers are populated by platform IaC.
AGENTCORE_REQUIREMENT_RUNTIME_ARN=
AGENTCORE_PROVISIONER_RUNTIME_ARN=
AGENTCORE_DEPLOYER_RUNTIME_ARN=
AGENTCORE_COMPLIANCE_RUNTIME_ARN=
